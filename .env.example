# ─────────────────────────────────────────────────────────────
# Vimal Mobiles CRM – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# Your Google Sheet ID (the long ID from the sheet URL)
SHEET_ID=1lNC-ovjjsjmikQ1fUX-UNYmtznGf0oi5VE4jKyYRs9I

# Path to your Google Service Account JSON key file.
# Download it from: Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
# Then share your Google Sheet with the service account email (give it Editor access).
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json

# Server port (default: 3000)
PORT=3000
